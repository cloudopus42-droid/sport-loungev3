PORT=5000
JWT_SECRET=replace-with-at-least-32-char-secret
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://cloudopus42-droid.github.io
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_DB_PASSWORD=your-db-password

# Telegram — each bot MUST use a UNIQUE token (create via @BotFather)
TELEGRAM_TOKEN=your-main-notification-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_API_BASE_URL=https://api.telegram.org
ORDER_BOT_TOKEN=your-order-bot-token
MANAGER_BOT_TOKEN=your-manager-bot-token
ADMIN_BOT_TOKEN=your-admin-bot-token
SUPPORT_BOT_TOKEN=your-support-bot-token
ADMIN_TELEGRAM_IDS=comma,separated,admin,chat,ids
ADMIN_TELEGRAM_USERNAMES=comma,separated,usernames
